{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "com.jonpot.forge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:40963",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
