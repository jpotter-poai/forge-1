# Directory where execution checkpoints are stored
CHECKPOINT_DIR=./checkpoints

# Directory where pipeline JSON definitions are saved
PIPELINE_DIR=./pipelines

# Directory containing block implementations (auto-discovered)
BLOCKS_DIR=./blocks

# Default file path for file-picker dialogs
